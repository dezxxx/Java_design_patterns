```plantuml
@startuml VisitorPattern

title Visitor Pattern - Installation Steps Example

interface InstallationStep {
    +accept(visitor: Visitor)
}

interface Visitor {
    +visit(step: PrepareStep)
    +visit(step: InstallFilesStep)
    +visit(step: FinishStep)
}

class PrepareStep {
    +accept(visitor: Visitor)
}

class InstallFilesStep {
    +accept(visitor: Visitor)
}

class FinishStep {
    +accept(visitor: Visitor)
}

class LoggingVisitor {
    +visit(step: PrepareStep)
    +visit(step: InstallFilesStep)
    +visit(step: FinishStep)
}

class Main {
    +main(args: String[]): void
}

InstallationStep <|.. PrepareStep
InstallationStep <|.. InstallFilesStep
InstallationStep <|.. FinishStep

Visitor <|.. LoggingVisitor

PrepareStep --> Visitor : accept()
InstallFilesStep --> Visitor : accept()
FinishStep --> Visitor : accept()

Main --> PrepareStep
Main --> InstallFilesStep
Main --> FinishStep
Main --> LoggingVisitor

@enduml
