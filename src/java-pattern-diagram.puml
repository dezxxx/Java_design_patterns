@startuml

title Factory Pattern

interface Guitar {
    +play() : void
}

interface GuitarFactory {
    +createGuitar() : Guitar
}

enum GuitarBrand {
    GIBSON
    IBANEZ
    LTD_BY_ESP
}

class GibsonGuitar {
    +play() : void
}

class IbanezGuitar {
    +play() : void
}

class LtdByEspGuitar {
    +play() : void
}

class GibsonGuitarFactory {
    +createGuitar() : Guitar
}

class IbanezGuitarFactory {
    +createGuitar() : Guitar
}

class LtdByEspGuitarFactory {
    +createGuitar() : Guitar
}

class GuitarFactoryProducer {
    +getFactory(brand : GuitarBrand) : GuitarFactory
}

class GuitarPlayApp {
    +main(args : String[]) : void
}

Guitar <|.. GibsonGuitar
Guitar <|.. IbanezGuitar
Guitar <|.. LtdByEspGuitar

GuitarFactory <|.. GibsonGuitarFactory
GuitarFactory <|.. IbanezGuitarFactory
GuitarFactory <|.. LtdByEspGuitarFactory

GibsonGuitarFactory --> GibsonGuitar : creates
IbanezGuitarFactory --> IbanezGuitar : creates
LtdByEspGuitarFactory --> LtdByEspGuitar : creates

GuitarFactoryProducer --> GuitarFactory : returns
GuitarFactoryProducer --> GuitarBrand : uses
GuitarPlayApp --> GuitarFactoryProducer : requests
GuitarPlayApp --> Guitar : plays

@enduml


